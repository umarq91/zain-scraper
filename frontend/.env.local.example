# GitHub Personal Access Token
# Classic PAT: needs "repo" + "workflow" scopes
# Fine-grained PAT: needs Contents (read/write) + Actions (read/write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Your GitHub username or org
GITHUB_OWNER=your-username

# The repo name (where config.json + state.json live)
GITHUB_REPO=zaib-stock-watcher
